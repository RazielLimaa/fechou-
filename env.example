# ── Adicione estas variáveis ao seu .env existente ───────────────────────────

# JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERE_UM_VALOR_ALEATORIO_DE_64_BYTES
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=GERE_OUTRO_VALOR_ALEATORIO_DIFERENTE_DO_ACIMA
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth — Client Secret NUNCA vai para o frontend
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=COLOQUE_O_SECRET_REGENERADO_AQUI
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# opcional: múltiplas URIs separadas por vírgula (ex.: ambientes dev/staging)
GOOGLE_REDIRECT_URI_LIST=http://localhost:3001/api/auth/google/callback,https://api.seudominio.com/api/auth/google/callback
# fluxo popup do Google Identity Services pode usar redirect "postmessage"

# CORS — domínios permitidos separados por vírgula
ALLOWED_ORIGINS=http://localhost:5173,https://seudominio.com.br
