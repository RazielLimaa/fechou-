# Base app
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgres://appuser:password@localhost:5432/fechou
PGHOST=localhost
PGPORT=5432
PGUSER=appuser
PGPASSWORD=password
PGDATABASE=fechou
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=20000
DB_STARTUP_MAX_ATTEMPTS=6
DB_STARTUP_RETRY_MS=2000
DB_REQUIRED_ON_STARTUP=false

# JWT and auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-64-byte-hex>
JWT_EXPIRES_IN=15m
JWT_ISSUER=fechou-api
JWT_AUDIENCE=fechou-client
JWT_REFRESH_SECRET=<generate-second-64-byte-hex>
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_ABSOLUTE_EXPIRES_IN=30d
JWT_REFRESH_REUSE_GRACE_MS=5000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<set-at-deploy-time>
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
GOOGLE_REDIRECT_URI_LIST=http://localhost:5173/auth/google/callback,http://localhost:3001/auth/google/callback

# Security keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKENS_ENCRYPTION_KEY=<32-bytes-base64>
SIGNATURES_MASTER_KEY=<32-bytes-base64>

# Mercado Pago OAuth and checkout
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_PUBLIC_KEY=
MP_REDIRECT_URI=http://localhost:3001/api/mercadopago/callback
MP_ACCESS_TOKEN=
MP_PLATFORM_ACCESS_TOKEN=
MP_API_BASE_URL=https://api.mercadopago.com
MP_AUTH_BASE_URL=https://auth.mercadopago.com.br
MERCADO_PAGO_HTTP_TIMEOUT_MS=8000
MERCADO_PAGO_GET_RETRIES=2

# Mercado Pago webhook validation
MERCADO_PAGO_PAYMENT_WEBHOOK_URL=http://localhost:3001/api/payments/webhook
MERCADO_PAGO_WEBHOOK_URL=http://localhost:3001/api/webhooks/mercadopago
MERCADO_PAGO_WEBHOOK_SECRET=
MP_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_MAX_SKEW_MS=300000
MERCADO_PAGO_WEBHOOK_SWEEP_MS=5000

# Mercado Pago subscriptions
# Use a Public Key and Access Token from the same Mercado Pago application.
# MP_ACCESS_TOKEN is the primary token used by the subscription flow; MP_SUBSCRIPTIONS_ACCESS_TOKEN remains as a legacy fallback.
# In the real flow, payer_email comes from the authenticated user's account email.
# Keep MP_SUBSCRIPTIONS_BACK_URL and webhooks on public HTTPS URLs.
MP_SUBSCRIPTIONS_ACCESS_TOKEN=
MP_SUBSCRIPTIONS_PUBLIC_KEY=
MP_SUBSCRIPTIONS_API_BASE_URL=https://api.mercadopago.com
MP_SUBSCRIPTIONS_PLAN_PRO_ID=
MP_SUBSCRIPTIONS_PLAN_PREMIUM_ID=
MP_SUBSCRIPTIONS_BACK_URL=https://your-public-domain.com/pagamento/confirmacao
MP_ALLOW_PRODUCTION_SUBSCRIPTIONS_IN_DEV=false
# Optional dev-only bypass when Mercado Pago /users/me still reports stale billing pending flags.
# Never enable in production.
MP_SUBSCRIPTIONS_SKIP_COLLECTOR_READINESS_CHECK=false
# Optional local simulation only. Keep commented/false in real environments.
# MP_SUBSCRIPTIONS_LOCAL_TEST_MODE=true
# MP_SUBSCRIPTIONS_TEST_PAYER_EMAIL=test_user_xxx@testuser.com

# Scripts compatibility
# Keep only if you still use scripts/create-mp-plans.*
MP_PLAN_PRO_ID=
MP_PLAN_PREMIUM_ID=

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=3000
RATE_LIMIT_AUTH_MAX=300
RATE_LIMIT_AUTH_DISTRIBUTED_MAX=120
RATE_LIMIT_AUTH_IDENTITY_MAX=60
RATE_LIMIT_AUTH_IDENTITY_WINDOW_MS=900000
RATE_LIMIT_CONTRACT_MAX=200
RATE_LIMIT_SENSITIVE_WINDOW_MS=600000
RATE_LIMIT_SENSITIVE_MAX=300
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=300
RATE_LIMIT_UPLOAD_MAX=60
RATE_LIMIT_PUBLIC_CONTRACT_MAX=120
RATE_LIMIT_PUBLIC_PAYMENT_CHECKOUT_MAX=50
RATE_LIMIT_PUBLIC_PAYMENT_CHECKOUT_WINDOW_MS=600000
RATE_LIMIT_PUBLIC_RATING_MAX=40
RATE_LIMIT_PUBLIC_RATING_READ_MAX=180
RATE_LIMIT_PUBLIC_PROPOSAL_GET_MAX=180
RATE_LIMIT_PUBLIC_PROPOSAL_GET_WINDOW_MS=600000
RATE_LIMIT_PUBLIC_PROPOSAL_SIGN_MAX=30
RATE_LIMIT_PUBLIC_PROPOSAL_SIGN_WINDOW_MS=600000
RATE_LIMIT_PROPOSAL_CANCEL_MAX=30
RATE_LIMIT_PROPOSAL_CANCEL_WINDOW_MS=600000
AUTH_STRICT_RATE_LIMITS=false

# Password reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=20
PASSWORD_RESET_CODE_TTL_MINUTES=10
PASSWORD_RESET_CODE_LENGTH=6
PASSWORD_RESET_CODE_MAX_ATTEMPTS=5
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_VERIFY_PATH=/reset-password/verify
PASSWORD_RESET_URL_BASE=
RATE_LIMIT_FORGOT_PASSWORD_MAX=20
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=900000
RATE_LIMIT_FORGOT_PASSWORD_IDENTITY_MAX=10
RATE_LIMIT_FORGOT_PASSWORD_IDENTITY_WINDOW_MS=3600000
RATE_LIMIT_FORGOT_PASSWORD_VERIFY_MAX=30
RATE_LIMIT_FORGOT_PASSWORD_VERIFY_WINDOW_MS=900000
RATE_LIMIT_FORGOT_PASSWORD_VERIFY_IDENTITY_MAX=15
RATE_LIMIT_FORGOT_PASSWORD_VERIFY_IDENTITY_WINDOW_MS=1800000
RATE_LIMIT_RESET_PASSWORD_MAX=30
RATE_LIMIT_RESET_PASSWORD_WINDOW_MS=900000

# Transactional email
MAIL_FROM=Fechou <no-reply@your-domain.com>
MAIL_REPLY_TO=support@your-domain.com
RESEND_API_KEY=<set-at-deploy-time>

# Stripe (optional, only if this flow is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=brl
STRIPE_MONTHLY_PLAN_PRICE_ID=
STRIPE_MONTHLY_PLAN2_PRICE_ID=

# Contract preview caches (optional tuning)
CONTRACT_PREVIEW_IMAGE_CACHE_MAX_ITEMS=400
CONTRACT_PREVIEW_AUTH_ASSET_CACHE_MAX_ITEMS=400
CONTRACT_PREVIEW_SIGNATURE_MAX_TTL_MS=900000
CONTRACT_PREVIEW_RENDER_CACHE_MAX_ITEMS=120
CONTRACT_PREVIEW_RENDER_CACHE_TTL_MS=900000
CONTRACT_PDF_CACHE_MAX_ITEMS=24
CONTRACT_PDF_CACHE_TTL_MS=90000
CONTRACT_PDF_BROWSER_IDLE_TTL_MS=45000
